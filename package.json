{
  "name": "aegis-protocol",
  "version": "0.0.1",
  "private": true,
  "description": "Camada de governança econômica para agentes de IA que pagam autonomamente via Stellar",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.5.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
