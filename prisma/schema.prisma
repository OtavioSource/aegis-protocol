// Aegis Protocol — Prisma schema
// Models serão adicionados na iteração 3 do roadmap (ver docs/03-domain-model.md):
// Company, User, Agent, Policy, Vendor, VendorWallet, SpendRequest, Approval,
// AuditEvent, TreasuryAccount, FiatDeposit, FiatWithdrawal.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
