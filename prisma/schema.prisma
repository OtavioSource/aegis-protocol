// ═══════════════════════════════════════════════════════════════
//  AEGIS PROTOCOL — PRISMA SCHEMA
//  Economic Governance Layer for AI Agents on Solana
// ═══════════════════════════════════════════════════════════════
//
// Domain model: 8 entities that together implement the core governance loop:
//
//   Agent requests spend → Policy evaluates → System decides
//   → Action is audited → Treasury execution is controlled
//
// Entity hierarchy:
//
//   Company ─┬─ Treasury  (Solana wallet, holds SPL tokens for payments)
//            └─ Agent ────┬─ Policy        (governance rules as JSON)
//                         ├─ Budget        (spending limits: daily/monthly/per-tx)
//                         └─ SpendRequest ─┬─ ApprovalRequest (human review queue)
//                                          └─ AuditLog        (immutable event trail)
//
// Key design decisions:
//
//   1. Policy.rules is stored as Json (not typed columns) because governance
//      rules evolve — new rule types shouldn't require DB migrations.
//      The schema for this JSON is enforced at the application layer via Zod.
//
//   2. Budget uses Decimal(18,6) to handle sub-cent USDC precision without
//      floating-point errors. JavaScript's Number type loses precision beyond
//      ~15 digits; Decimal avoids that for financial amounts.
//
//   3. AuditLog has compound indexes on (companyId, createdAt) and
//      (agentId, createdAt) because the dashboard always queries logs
//      ordered by time within a company or agent scope.
//
//   4. Agent.apiKeyHash is @unique — the index that makes O(1) API key
//      lookup possible without ever storing the plaintext key.
//
//   5. Treasury.encryptedSecret is never exposed in API responses.
//      It's stripped at the route layer before any JSON serialization.

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Company ──────────────────────────────────────────────────────────────────
// The top-level tenant. All other entities belong to a company.
// Multi-tenant isolation: every API query filters by companyId.
// The slug is a human-readable identifier (e.g., "acme-corp") for URLs and logs.

model Company {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique // Human-readable ID, globally unique
  merkleTreeAddress String?           // Bubblegum cNFT tree for audit receipts (created lazily)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  treasuries    Treasury[]
  agents        Agent[]
  budgets       Budget[]
  vendors       Vendor[]
  users         User[]
  spendRequests SpendRequest[]
  auditLogs     AuditLog[]

  @@map("companies")
}

// ─── Vendor ───────────────────────────────────────────────────────────────────
// Vendors are the recipients of Solana payments. Each vendor has a registered
// Solana wallet address. When a spend request is executed, the SPL token transfer
// goes to the vendor's wallet — not a self-transfer.
//
// Vendors are company-scoped (@@unique on companyId + name) so "OpenAI" can exist
// in multiple companies without conflicts.
//
// The policy engine's vendorAllowList and vendorDenyList use vendor names (strings).
// The Vendor model stores the actual wallet address needed for execution.

model Vendor {
  id            String       @id @default(cuid())
  companyId     String
  name          String                                 // Must match vendor names in policy rules
  walletAddress String                                 // Solana public key (base58) — transfer destination
  description   String?                               // Optional: what this vendor provides
  status        VendorStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, name])  // One wallet per vendor name per company
  @@map("vendors")
}

enum VendorStatus {
  ACTIVE   // Vendor is operational — payments allowed
  BLOCKED  // Vendor is blocked — payments rejected (belt-and-suspenders with deny list)
}

// ─── Treasury ─────────────────────────────────────────────────────────────────
// A Solana wallet that executes payments. One company can have multiple treasuries
// (e.g., one per team). Each agent links to exactly one treasury.
//
// walletAddress: public Solana address (base58) — safe to expose, shows on Explorer
// encryptedSecret: base64-encoded keypair secret — NEVER returned in API responses
//                  In production: wrap with AES-256-GCM before storing
// status: ACTIVE (operational) | FROZEN (kill switch, no transfers allowed)

model Treasury {
  id              String         @id @default(cuid())
  companyId       String
  name            String
  network         String         @default("devnet")    // "devnet" | "mainnet-beta"
  baseCurrency    String         @default("USDC")
  walletAddress   String         @unique               // Public — shown in UI and Explorer links
  encryptedSecret String                               // Private — server-side only, never exposed
  status          TreasuryStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents  Agent[]

  @@map("treasuries")
}

enum TreasuryStatus {
  ACTIVE  // Normal operation — transfers allowed
  FROZEN  // Kill switch engaged — no transfers, treasury locked
}

// ─── Agent ────────────────────────────────────────────────────────────────────
// A registered AI agent with controlled economic autonomy.
//
// apiKeyHash: SHA-256 of the raw API key. Indexed for O(1) lookup.
//             Raw key returned ONCE at registration, never stored.
//
// killSwitchActive: BOOLEAN EMERGENCY STOP.
//                   When true, ALL spend requests are blocked (Rule 1 in policy engine,
//                   highest priority, evaluated before any other check).
//                   Toggle via POST /agents/:id/kill-switch
//
// status: ACTIVE = normal | DISABLED = permanent soft-disable (kill switch is temporary)

model Agent {
  id               String      @id @default(cuid())
  companyId        String
  treasuryId       String?                            // Optional: link to spending wallet
  name             String
  externalAgentId  String?                            // ID from LangChain, CrewAI, etc.
  type             String                             // e.g., "marketing-bot", "infra-agent"
  status           AgentStatus @default(ACTIVE)
  killSwitchActive Boolean     @default(false)        // THE EMERGENCY STOP
  ownerName        String?                            // Responsible human for this agent
  ownerEmail       String?
  apiKeyHash       String      @unique                // SHA-256 hash — never plaintext
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  treasury      Treasury?      @relation(fields: [treasuryId], references: [id])
  policies      Policy[]
  budgets       Budget[]
  spendRequests SpendRequest[]
  auditLogs     AuditLog[]

  @@map("agents")
}

enum AgentStatus {
  ACTIVE    // Normal operation — spend requests are evaluated
  DISABLED  // Permanently disabled — all requests blocked (soft delete)
}

// ─── Policy ───────────────────────────────────────────────────────────────────
// Governance rules for an agent, stored as JSON for schema flexibility.
// At most ONE policy is active per agent at a time.
// Previous policies are preserved (active: false) for audit history.
//
// rules JSON shape (see PolicyRules type in @aegis/shared):
//   {
//     "maxTransactionAmount": 50,        // Hard ceiling per transaction
//     "requireApprovalAbove": 10,        // Escalate to human above this
//     "vendorAllowList": ["OpenAI"],     // Whitelist mode (empty = all allowed)
//     "vendorDenyList": ["BadVendor"],   // Always blocked, regardless of allowlist
//     "allowedActionTypes": ["purchase_api_access"]  // Restrict action categories
//   }

model Policy {
  id        String   @id @default(cuid())
  agentId   String
  name      String
  rules     Json     // PolicyRules — validated by Zod at API layer
  active    Boolean  @default(true)  // Only one active per agent (enforced by route)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("policies")
}

// ─── Budget ───────────────────────────────────────────────────────────────────
// Per-agent spending limits enforced by the policy engine.
// Separate from Policy because budgets change frequently (monthly reviews)
// while policy rules change rarely (security/governance decisions).
//
// All three limits are checked independently — being under daily limit
// but over monthly limit still blocks the request.
//
// Decimal(18,6) handles USDC amounts with 6-digit precision without
// floating-point errors. 1 USDC = 1.000000 in this representation.
//
// @unique on agentId: one budget per agent, enforced at DB level.
// Updating a budget uses upsert in the API (no duplicate records).

model Budget {
  id                  String   @id @default(cuid())
  companyId           String
  agentId             String   @unique                    // One budget per agent
  dailyLimit          Decimal  @db.Decimal(18, 6)        // Rolling 24h ceiling
  monthlyLimit        Decimal  @db.Decimal(18, 6)        // Rolling 30d ceiling
  perTransactionLimit Decimal  @db.Decimal(18, 6)        // Per-transaction ceiling
  currency            String   @default("USDC")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@map("budgets")
}

// ─── SpendRequest ─────────────────────────────────────────────────────────────
// THE CENTRAL ENTITY. Created by AI agents, evaluated by the policy engine,
// executed via Solana SPL token transfer.
//
// Lifecycle: PENDING → APPROVED | REJECTED | REQUIRES_APPROVAL → EXECUTED | FAILED
//
// policyDecision: the raw output from evaluate() — immutable after creation.
//                 Captures WHAT the policy engine decided.
// status:         operational state — changes as the request flows through the system.
//                 A REQUIRES_APPROVAL request becomes APPROVED after human review.
//
// txSignature: Solana transaction signature. Set after successful /execute call.
//              Verifiable on Solana Explorer at:
//              https://explorer.solana.com/tx/<txSignature>?cluster=devnet
//
// explorerUrl: pre-formatted link to the Solana Explorer transaction page.
//              Stored so the dashboard can render clickable links without
//              re-computing the URL format.

model SpendRequest {
  id              String             @id @default(cuid())
  companyId       String
  agentId         String
  actionType      String                                   // "purchase_api_access", "buy_compute", etc.
  vendor          String                                   // Recipient name (checked against allow/deny lists)
  amount          Decimal            @db.Decimal(18, 6)   // Amount in baseCurrency (e.g., 15.5 USDC)
  currency        String             @default("USDC")
  reason          String                                   // Agent's explanation for the spend
  reference       String?                                  // Optional external reference (invoice ID, etc.)
  status          SpendRequestStatus @default(PENDING)     // Operational lifecycle state
  policyDecision  String?                                  // Policy engine output (immutable after creation)
  decisionReason  String?                                  // Human-readable explanation of the decision
  matchedRule     String?                                  // Which rule triggered: 'kill_switch', 'vendor_denied', etc.
  txSignature         String?                                  // Solana tx signature (set after /execute)
  explorerUrl         String?                                  // Direct Solana Explorer link (set after /execute)
  vendorWalletAddress String?                                  // Vendor's Solana wallet that received the payment
  metadata            Json               @default("{}")        // Agent-provided context: model used, trace ID, etc.
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  company         Company           @relation(fields: [companyId], references: [id])
  agent           Agent             @relation(fields: [agentId], references: [id])
  approvalRequest ApprovalRequest?
  auditLogs       AuditLog[]

  @@map("spend_requests")
}

enum SpendRequestStatus {
  PENDING            // Initial state (immediately evaluated, rarely stays here long)
  APPROVED           // Policy auto-approved (or human approved) — ready for /execute
  REQUIRES_APPROVAL  // Policy escalated to human review queue
  REJECTED           // Policy blocked it — no Solana transfer will occur
  EXECUTED           // Solana transfer confirmed on-chain (txSignature populated)
  FAILED             // Policy approved but Solana execution failed (network/funds issue)
}

// ─── ApprovalRequest ──────────────────────────────────────────────────────────
// Human review record for spend requests that exceeded the approval threshold.
// One-to-one with SpendRequest (@unique on spendRequestId).
//
// Created automatically when the policy engine returns REQUIRES_APPROVAL.
// Appears in GET /approvals/pending for the admin dashboard.
//
// After approve:
//   ApprovalRequest.status → APPROVED
//   SpendRequest.status → APPROVED (ready for /execute)
//
// After reject:
//   ApprovalRequest.status → REJECTED
//   SpendRequest.status → REJECTED (terminal, no Solana transfer)

model ApprovalRequest {
  id             String         @id @default(cuid())
  spendRequestId String         @unique              // One ApprovalRequest per SpendRequest
  approverEmail  String?                             // Optional: who approved/rejected
  status         ApprovalStatus @default(PENDING)
  decisionReason String?                             // Optional: admin's note explaining the decision
  decidedAt      DateTime?                           // When the human acted (null if still pending)
  createdAt      DateTime       @default(now())

  spendRequest SpendRequest @relation(fields: [spendRequestId], references: [id], onDelete: Cascade)

  @@map("approval_requests")
}

enum ApprovalStatus {
  PENDING   // Waiting in the dashboard approval queue
  APPROVED  // Human approved — SpendRequest can proceed to /execute
  REJECTED  // Human rejected — SpendRequest is terminal
}

// ─── User ─────────────────────────────────────────────────────────────────────
// Admin users who manage the Aegis Protocol dashboard.
// Separate from Agents — agents are AI processes, users are humans.
//
// passwordHash: bcrypt hash of the password (never stored in plaintext)
// notifyEmail: if true, user receives email when a spend request needs approval
// notifySms: reserved for future SMS integration (Twilio)
// role: OWNER can do anything; ADMIN can approve/reject; VIEWER is read-only

model User {
  id           String   @id @default(cuid())
  companyId    String
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(ADMIN)
  phone        String?
  notifyEmail  Boolean  @default(true)
  notifySms    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("users")
}

enum UserRole {
  OWNER   // Full access — can manage users and treasury
  ADMIN   // Can approve/reject requests, manage agents and policies
  VIEWER  // Read-only access to dashboard
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────
// Immutable event trail. Every governance decision, state change, and admin action
// is recorded here. Never updated or deleted.
//
// The payload field stores event-specific context as JSON:
//   - SPEND_REQUEST_EXECUTED: { txSignature, explorerUrl, amount }
//   - KILL_SWITCH_ACTIVATED: { reason, previousState }
//   - SPEND_REQUEST_REJECTED: { matchedRule, reason }
//   - POLICY_ASSIGNED: { policyId, policyName, rules }
//
// Indexes:
//   (companyId, createdAt) — dashboard company-level audit log, time-ordered
//   (agentId, createdAt)   — per-agent audit log, time-ordered
//   (spendRequestId)       — all events for a specific spend request

model AuditLog {
  id             String   @id @default(cuid())
  companyId      String
  agentId        String?                  // null for company-level events (treasury creation, etc.)
  spendRequestId String?                  // null for non-spend events (kill switch, policy assignment, etc.)
  eventType      String                   // AuditEventType string value
  actorType      String                   // ActorType: AGENT | ADMIN | SYSTEM | APPROVER
  actorId        String                   // agent ID, 'admin', 'policy-engine', 'treasury'
  payload        Json     @default("{}")  // Event-specific context (freeform, never schema-locked)
  createdAt      DateTime @default(now()) // Immutable timestamp — no updatedAt by design

  company      Company       @relation(fields: [companyId], references: [id])
  agent        Agent?        @relation(fields: [agentId], references: [id])
  spendRequest SpendRequest? @relation(fields: [spendRequestId], references: [id])

  @@index([companyId, createdAt]) // Time-range queries within a company
  @@index([agentId, createdAt])   // Time-range queries for a specific agent
  @@index([spendRequestId])       // Lookup all events for a spend request
  @@map("audit_logs")
}
