# Database (Neon / Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/commandrail?sslmode=require"

# Server
PORT=3001
NODE_ENV=production

# Admin
ADMIN_EMAIL=admin@yourcompany.com

# Solana — use http://localhost:8899 for local validator, https://api.devnet.solana.com for devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Demo token mint (created via POST /companies/:id/treasuries/:id/fund-demo, devnet only)
# DEVNET_DEMO_MINT_ADDRESS=

# Demo credentials (populated from db:seed output)
# DEMO_API_KEY=cr_...
# DEMO_COMPANY_ID=...

# Email notifications via Resend (https://resend.com — free tier: 100/day)
# Optional: if not set, notifications are silently skipped
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=CommandRail <noreply@yourdomain.com>
# DASHBOARD_URL=http://localhost:3000
