# Database (Neon / Railway PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/aegis?sslmode=require"

# Server
PORT=3001
NODE_ENV=production

# Admin
ADMIN_EMAIL=admin@yourcompany.com

# Solana — use http://localhost:8899 for local validator, https://api.devnet.solana.com for devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Token-2022 demo mint (created via POST /companies/:id/treasuries/:id/fund-demo, devnet only)
# This is a Token-2022 mint with PermanentDelegate extension — NOT standard SPL USDC.
# DEVNET_DEMO_MINT_ADDRESS=

# Aegis Permanent Delegate — Token-2022 kill switch authority
# This keypair can sweep tokens from ANY treasury using this mint (on-chain kill switch).
# Generate with: import { generateMintAuthority } from '@aegis/solana'; generateMintAuthority()
# KEEP SECRET — treat like a root private key.
# AEGIS_DELEGATE_SECRET=<base64-encoded keypair>

# Quarantine wallet — where swept tokens go when kill switch is activated
# Defaults to the delegate's own wallet if not set.
# AEGIS_QUARANTINE_ADDRESS=<solana-wallet-address>

# Mint authority (optional — if set, this keypair mints tokens; otherwise treasury is self-authorizing)
# DEVNET_DEMO_MINT_AUTHORITY_SECRET=<base64-encoded keypair>

# Demo credentials (populated from db:seed output)
# DEMO_API_KEY=cr_...
# DEMO_COMPANY_ID=...

# ─── Stellar (cross-currency path payment chain) ─────────────────────────────
# Optional: only required when treasury.network is stellar-testnet/stellar-mainnet.
# A pure-Solana deployment can leave these unset.

# Horizon RPC URL — leave unset to use the default public testnet/mainnet endpoints
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Slippage tolerance for path quotes, in basis points (100 = 1%, default 100)
# STELLAR_SLIPPAGE_BPS=100

# Demo asset issuers — populated by `pnpm --filter @aegis/stellar setup-demo`
# Required only when running the cross-currency demo on testnet.
# STELLAR_DEMO_USDC_ISSUER=G...
# STELLAR_DEMO_EURC_ISSUER=G...

# Demo issuer secrets — required by POST /treasuries/:id/fund-demo on Stellar
# (used to mint USDC/EURC to fresh treasuries for the demo). Format: base64
# of the S... secret. Printed by setup-demo.
# STELLAR_DEMO_USDC_ISSUER_SECRET=<base64-of-S...>
# STELLAR_DEMO_EURC_ISSUER_SECRET=<base64-of-S...>

# Email notifications via Resend (https://resend.com — free tier: 100/day)
# Optional: if not set, notifications are silently skipped
# RESEND_API_KEY=re_...
# NOTIFICATION_FROM_EMAIL=Aegis Protocol <noreply@yourdomain.com>
# DASHBOARD_URL=http://localhost:3000
