# ===== Server =====
NODE_ENV=development
HOST=0.0.0.0
PORT=4000
LOG_LEVEL=info

# ===== Database (Prisma + Neon) =====
# DATABASE_URL: pooled connection (com `-pooler` no hostname).
#   Usado pelo Prisma Client em runtime. Pooler evita "too many connections"
#   sob carga e cold starts do Neon free tier.
# DIRECT_URL: direct connection (sem `-pooler`).
#   Usado pelo Prisma CLI (`prisma migrate`, `prisma db push`, `prisma studio`)
#   porque essas operações exigem conexão persistente que o PgBouncer não suporta.
# Ambas as URLs vêm do mesmo Neon project — copie do dashboard alternando
# o toggle "Connection pooling".
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.region.aws.neon.tech/aegis?sslmode=require&channel_binding=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST.region.aws.neon.tech/aegis?sslmode=require&channel_binding=require

# Para dev local com Docker (alternativa ao Neon, ver docker-compose.yml):
# DATABASE_URL=postgresql://aegis:aegis_dev_password@localhost:5432/aegis?schema=public
# DIRECT_URL=postgresql://aegis:aegis_dev_password@localhost:5432/aegis?schema=public

# ===== Stellar network =====
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ===== Treasury (hot wallet — MVP testnet apenas) =====
# Gere com: const kp = Keypair.random(); console.log(kp.publicKey(), kp.secret())
# Fundar testnet: curl "https://friendbot.stellar.org?addr=<publicKey>"
TREASURY_PUBLIC_KEY=G_REPLACE_ME
TREASURY_SECRET=S_REPLACE_ME

# ===== Anchor SEP-24 (test-anchor) =====
SEP24_ANCHOR_HOME_DOMAIN=testanchor.stellar.org
SEP24_ANCHOR_TOML_URL=https://testanchor.stellar.org/.well-known/stellar.toml

# ===== Asset operacional (resolvido via anchor TOML) =====
USDC_ASSET_CODE=USDC
USDC_ASSET_ISSUER=G_REPLACE_ME_VIA_ANCHOR_TOML

# ===== Soroban audit contract =====
# Preencher após `stellar contract deploy` (setup-treasury script)
AUDIT_CONTRACT_ID=C_REPLACE_ME

# ===== Auth / Web =====
# Secret usado pelo NextAuth para assinar cookies/JWTs
NEXTAUTH_SECRET=replace_me_random_32_chars
NEXTAUTH_URL=http://localhost:3000

# ===== Tuning =====
SEP24_POLLING_INTERVAL_MS=30000
SEP24_JWT_TTL_SECONDS=82800
RATE_LIMIT_PER_AGENT_RPS=10
IDEMPOTENCY_KEY_TTL_DAYS=7
