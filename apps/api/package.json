{
  "name": "@aegis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "db:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio --schema ../../prisma/schema.prisma",
    "demo": "tsx --env-file=.env src/scripts/demo.ts"
  },
  "dependencies": {
    "@aegis/policy-engine": "workspace:*",
    "@aegis/shared": "workspace:*",
    "@aegis/solana": "workspace:*",
    "@aegis/stellar": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.1",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "nanoid": "^5.1.5",
    "pino-pretty": "^13.1.3",
    "resend": "^6.10.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.6.0",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
