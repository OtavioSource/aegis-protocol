{
  "name": "@aegis/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "dotenv -e .env.local -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint placeholder — eslint configured later'",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:seed": "dotenv -e .env.local -- prisma db seed",
    "db:seed:demo": "dotenv -e .env.local -- tsx prisma/seed-demo.ts",
    "db:reset:demo": "dotenv -e .env.local -- tsx prisma/reset-demo.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "setup:treasury": "dotenv -e .env.local -- tsx src/scripts/setup-treasury.ts",
    "setup:etherfuse": "dotenv -e .env.local -- tsx src/scripts/setup-etherfuse.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aegis/policy-engine": "workspace:*",
    "@aegis/shared": "workspace:*",
    "@aegis/stellar": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "^6.1.0",
    "@x402/core": "^2.13.0",
    "@x402/stellar": "^2.12.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "lru-cache": "^11.0.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
