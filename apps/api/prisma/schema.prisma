// Aegis Protocol — Prisma schema
//
// Modela as 12 entidades do domínio (ver docs/03-domain-model.md).
// Multi-tenancy: toda entidade tenant-bound carrega `companyId` (RNF6).
// Convenções:
//   - IDs UUID via @db.Uuid + @default(uuid())
//   - Tabelas snake_case via @@map
//   - Enums alinhados com @aegis/shared/enums.ts
//   - Valores monetários em BigInt (centavos USD)
//   - Indexes em FKs + campos de query frequente
//   - onDelete: Cascade em FKs para Company (testes / cleanup)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// Enums (espelham @aegis/shared/enums.ts)
// ============================================================================

enum ChainType {
  STELLAR
}

enum Network {
  TESTNET
  MAINNET
}

enum UserRole {
  OWNER
  ADMIN
  VIEWER
}

enum AgentStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

enum VendorStatus {
  ACTIVE
  SUSPENDED
}

enum VendorWalletStatus {
  PROVISIONING
  ACTIVE
  SPONSORED_BY_AEGIS
  INACTIVE
}

enum VendorSignMode {
  AEGIS
  SELF
}

enum SpendRequestStatus {
  CREATED
  APPROVED
  REQUIRES_APPROVAL
  REJECTED
  APPROVED_BY_HUMAN
  REJECTED_BY_HUMAN
  EXPIRED
  // Não-custodial (multisig 5a): policy aprovou, Aegis emitiu o envelope,
  // aguardando assinatura da agent key via /cosign. Ver ADR 0007 §5.
  AWAITING_AGENT_SIGNATURE
  EXECUTING
  EXECUTED
  EXECUTION_FAILED
}

// Espelham @aegis/shared/enums — manter sincronizado.
enum WalletStatus {
  PROVISIONING
  ACTIVE
}

enum OwnerKeyMode {
  GENERATED
  EXTERNAL
}

enum DecisionType {
  APPROVED
  REQUIRES_APPROVAL
  REJECTED
}

enum ApprovalAction {
  APPROVED
  REJECTED
}

enum EventType {
  DECISION_MADE
  PAYMENT_EXECUTED
  PAYMENT_FAILED
  APPROVAL_REQUESTED
  APPROVAL_GRANTED
  APPROVAL_DENIED
  KILL_SWITCH_ACTIVATED
  FIAT_DEPOSITED
  FIAT_WITHDRAWN
}

enum FiatTransactionStatus {
  INITIATED
  PENDING_USER_INFO
  PENDING_USER_TRANSFER
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================================================
// Models
// ============================================================================

model Company {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @db.VarChar(200)
  slug               String   @unique @db.VarChar(100)
  monthlyBudgetCents BigInt?
  defaultPolicyId    String?  @db.Uuid
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users           User[]
  agents          Agent[]
  policies        Policy[]
  vendors         Vendor[]
  wallets         Wallet[]
  spendRequests   SpendRequest[]
  auditEvents     AuditEvent[]
  fiatDeposits    FiatDeposit[]
  fiatWithdrawals FiatWithdrawal[]

  @@map("company")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(255)
  name         String    @db.VarChar(200)
  /// bcrypt/argon2 hash. NULL para usuários OAuth-only.
  passwordHash String?   @db.VarChar(255)
  role         UserRole  @default(VIEWER)
  companyId    String    @db.Uuid
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  approvals Approval[]

  @@index([companyId])
  @@map("user")
}

model Agent {
  id             String      @id @default(uuid()) @db.Uuid
  companyId      String      @db.Uuid
  name           String      @db.VarChar(200)
  description    String?     @db.Text
  /// hash bcrypt/argon2 da API key completa
  apiKeyHash     String      @unique
  /// primeiros chars (ex: "cr_a8x9k2j") para listagem segura no dashboard
  apiKeyPrefix   String      @db.VarChar(20)
  activePolicyId String      @db.Uuid
  /// Carteira (centro de custo) de onde o agente gasta. Ver ADR 0007 §4.
  walletId       String?     @db.Uuid
  /// Pubkey Stellar do agente — signer peso 1 na conta da carteira (modelo 5a).
  /// A secret é gerada client-side e entregue ao dev; só a pubkey é persistida.
  signerPubKey   String?     @db.VarChar(64)
  status         AgentStatus @default(ACTIVE)
  metadata       Json        @default("{}")
  revokedAt      DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  activePolicy  Policy         @relation(fields: [activePolicyId], references: [id])
  wallet        Wallet?        @relation(fields: [walletId], references: [id])
  spendRequests SpendRequest[]

  @@index([companyId])
  @@index([apiKeyPrefix])
  @@index([walletId])
  @@map("agent")
}

model Policy {
  id                 String   @id @default(uuid()) @db.Uuid
  companyId          String   @db.Uuid
  name               String   @db.VarChar(200)
  version            Int      @default(1)
  /// PolicyRules JSON conforme PolicyRulesSchema de @aegis/shared
  rules              Json
  isActive           Boolean  @default(true)
  supersedesPolicyId String?  @db.Uuid
  createdAt          DateTime @default(now())

  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supersedesPolicy Policy?        @relation("PolicyVersions", fields: [supersedesPolicyId], references: [id])
  nextVersions     Policy[]       @relation("PolicyVersions")
  agents           Agent[]
  spendRequests    SpendRequest[]

  @@index([companyId, isActive])
  @@map("policy")
}

model Vendor {
  id             String       @id @default(uuid()) @db.Uuid
  companyId      String       @db.Uuid
  name           String       @db.VarChar(200)
  description    String?      @db.Text
  /// Website/domínio do vendor (ex.: "firecrawl.dev"). Identifica o beneficiário.
  website        String?      @db.VarChar(255)
  /// Categoria do serviço (ex.: "scraping", "llm-api", "compute").
  category       String?      @db.VarChar(64)
  /// Email de contato do vendor (suporte/disputas).
  contactEmail   String?      @db.VarChar(255)
  /// Asset preferido do vendor: USDC default; aceita EURC, BRL, ARS, etc. (RF11)
  preferredAsset String       @default("USDC") @db.VarChar(12)
  metadata       Json         @default("{}")
  status         VendorStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  wallets       VendorWallet[]
  spendRequests SpendRequest[]

  @@index([companyId])
  @@map("vendor")
}

model VendorWallet {
  id                 String             @id @default(uuid()) @db.Uuid
  vendorId           String             @db.Uuid
  chain              ChainType          @default(STELLAR)
  publicKey          String             @db.VarChar(64)
  /// Secret key cifrada com VENDOR_KEY_ENCRYPTION_KEY (Modo AEGIS only). Null em Modo SELF.
  secretKeyEncrypted String?            @db.Text
  signMode           VendorSignMode     @default(AEGIS)
  status             VendorWalletStatus @default(PROVISIONING)
  /// Trustlines abertas, ex: [{"asset":"USDC","issuer":"GD...","sponsored":true}]
  trustlines         Json               @default("[]")
  sponsorshipTxHash  String?            @db.VarChar(128)
  isPrimary          Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  vendor        Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  spendRequests SpendRequest[]

  @@unique([vendorId, publicKey])
  @@index([vendorId, isPrimary])
  @@map("vendor_wallet")
}

model SpendRequest {
  id             String  @id @default(uuid()) @db.Uuid
  companyId      String  @db.Uuid
  agentId        String  @db.Uuid
  vendorId       String  @db.Uuid
  /// Resolvido na execução (PROVISIONING wallets ainda não elegíveis)
  vendorWalletId String? @db.Uuid
  /// Carteira de origem do pagamento (derivada de agent.walletId; persistida p/ auditoria).
  walletId       String? @db.Uuid
  policyId       String  @db.Uuid
  /// Snapshot do Policy.rules no momento da decisão — auditoria histórica
  policySnapshot Json

  amountCents BigInt
  asset       String  @db.VarChar(12)
  actionType  String  @db.VarChar(64)
  reason      String? @db.Text
  metadata    Json    @default("{}")

  /// (companyId, idempotencyKey) unique — RNF2
  idempotencyKey String @db.VarChar(128)

  status         SpendRequestStatus @default(CREATED)
  decision       DecisionType?
  decisionReason String?            @db.Text
  evaluatedAt    DateTime?

  /// Não-custodial (5a): envelope canônico não-assinado emitido pelo Aegis ao
  /// aprovar. O agente assina e devolve no /cosign; validamos por igualdade de
  /// hash. NULL fora do fluxo multisig. Ver ADR 0007 §5/§6.
  envelopeXdr    String?            @db.Text

  txHash             String? @db.VarChar(128)
  ledger             Int?
  sorobanEventTxHash String? @db.VarChar(128)
  executedAt         DateTime?
  failureReason      String? @db.Text
  /// Anti-replay do comprovante x402: setado quando o txHash é resgatado com
  /// sucesso em POST /v1/x402/verify. NULL = ainda não consumido. Uma prova só
  /// pode ser resgatada uma vez (o ledger é público → txHash não é segredo).
  x402RedeemedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent        Agent         @relation(fields: [agentId], references: [id])
  vendor       Vendor        @relation(fields: [vendorId], references: [id])
  vendorWallet VendorWallet? @relation(fields: [vendorWalletId], references: [id])
  wallet       Wallet?       @relation(fields: [walletId], references: [id])
  policy       Policy        @relation(fields: [policyId], references: [id])
  approval     Approval?
  auditEvents  AuditEvent[]

  @@unique([companyId, idempotencyKey])
  @@index([companyId, status, createdAt])
  @@index([agentId, status])
  @@index([txHash])
  @@map("spend_request")
}

model Approval {
  id             String         @id @default(uuid()) @db.Uuid
  spendRequestId String         @unique @db.Uuid
  userId         String         @db.Uuid
  action         ApprovalAction
  reason         String?        @db.Text
  createdAt      DateTime       @default(now())

  spendRequest SpendRequest @relation(fields: [spendRequestId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("approval")
}

model AuditEvent {
  id             String    @id @default(uuid()) @db.Uuid
  companyId      String    @db.Uuid
  spendRequestId String?   @db.Uuid
  eventType      EventType
  /// "agent:<id>" | "user:<id>" | "system" | "anchor:<provider>"
  actor          String    @db.VarChar(128)
  payload        Json
  /// NULL = ainda não emitido na chain (worker está processando com retry)
  sorobanTxHash    String?   @db.VarChar(128)
  sorobanEmittedAt DateTime?
  createdAt        DateTime  @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  spendRequest SpendRequest? @relation(fields: [spendRequestId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([spendRequestId])
  @@index([sorobanTxHash])
  @@map("audit_event")
}

/// Carteira não-custodial (conta Stellar multisig) de uma company. Ver ADR 0007.
/// Substitui o antigo TreasuryAccount custodial (modelo de pote global removido).
model Wallet {
  id        String  @id @default(uuid()) @db.Uuid
  companyId String  @db.Uuid
  /// Rótulo do centro de custo: "marketing", "devops", etc.
  label     String  @db.VarChar(120)
  network   Network @default(TESTNET)
  /// Endereço da conta = master pubkey do dono. A secret NUNCA é persistida
  /// (gerada client-side ou trazida pelo dono via Freighter).
  address   String  @db.VarChar(64)
  /// GENERATED = Aegis gerou client-side; EXTERNAL = dono trouxe a própria wallet.
  ownerKeyMode      OwnerKeyMode
  /// Pubkey do co-signer do Aegis para esta company (peso 1). A secret é derivada
  /// on-demand (HKDF de seed-raiz + companyId) e NUNCA é persistida. Ver ADR 0007 §8.
  aegisSignerPubKey String       @db.VarChar(64)
  status            WalletStatus @default(PROVISIONING)
  /// Hash da tx de setOptions que aplicou signers + thresholds no onboarding.
  setupTxHash       String?      @db.VarChar(128)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agents        Agent[]
  spendRequests SpendRequest[]

  @@unique([companyId, address])
  @@index([companyId])
  @@map("wallet")
}

/// Captação de leads / waitlist da landing. Criada fora do Prisma originalmente;
/// modelada aqui para o Prisma gerenciá-la e NÃO dropar no db push.
model Lead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  role      String?
  company   String?
  profile   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("leads")
}

model FiatDeposit {
  id                  String                @id @default(uuid()) @db.Uuid
  companyId           String                @db.Uuid
  userId              String                @db.Uuid
  /// Carteira não-custodial de destino do crédito (Etherfuse). NULL = legado/treasury (SEP-24).
  walletId            String?               @db.Uuid
  /// Provider do anchor: "stellar-test-anchor" (SEP-24) | "etherfuse-sandbox" | "etherfuse"
  anchorId            String                @db.VarChar(64)
  anchorTransactionId String                @db.VarChar(128)
  /// SEP-24: URL hosted interactive (KYC + dados bancários no anchor).
  /// Etherfuse: NULL — instruções vêm em `instructions` (Pix key, valor, expiração).
  interactiveUrl      String?               @db.Text
  /// Etherfuse: { pixKey, pixValue, expiresAt, qrCode? } ou outros campos do provider.
  instructions        Json?
  /// Source asset que o usuário paga (BRL, MXN, USD). NULL = mesma do `asset`.
  sourceAsset         String?               @db.VarChar(12)
  /// Source amount em smallest unit (centavos BRL, etc.). NULL = derivado de amountCents.
  sourceAmountCents   BigInt?
  /// Target asset que entra na treasury (USDC, EURC, TESOURO).
  amountCents         BigInt?
  actualAmountCents   BigInt?
  asset               String                @db.VarChar(12)
  status              FiatTransactionStatus @default(INITIATED)
  /// Hash da tx Stellar que creditou o asset na treasury
  txHash              String?               @db.VarChar(128)
  failureReason       String?               @db.Text
  createdAt           DateTime              @default(now())
  completedAt         DateTime?
  updatedAt           DateTime              @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([anchorTransactionId])
  @@map("fiat_deposit")
}

model FiatWithdrawal {
  id                    String                @id @default(uuid()) @db.Uuid
  companyId             String                @db.Uuid
  userId                String                @db.Uuid
  /// Provider do anchor: "stellar-test-anchor" (SEP-24) | "etherfuse-sandbox" | "etherfuse-prod"
  anchorId              String                @db.VarChar(64)
  anchorTransactionId   String                @db.VarChar(128)
  /// SEP-24: URL hosted interactive. Etherfuse: NULL (off-ramp via burnTransaction assinada).
  interactiveUrl        String?               @db.Text
  /// Etherfuse: { targetFiat, destinationAmount, exchangeRate, statusPage }.
  instructions          Json?
  /// Asset Stellar que sai da treasury (USDC). amountCents = valor em centavos.
  amountCents           BigInt?
  actualAmountCents     BigInt?
  asset                 String                @db.VarChar(12)
  /// Moeda fiat recebida pelo off-ramp (BRL, MXN). NULL = não-fiat / SEP-24.
  targetFiat            String?               @db.VarChar(12)
  status                FiatTransactionStatus @default(INITIATED)
  /// Hash da tx Stellar que enviou USDC da treasury para o anchor
  txHash                String?               @db.VarChar(128)
  bankReference         String?               @db.VarChar(128)
  /// Dados bancários (mascarados no display); estrutura definida pelo anchor
  withdrawalDestination Json?
  failureReason         String?               @db.Text
  createdAt             DateTime              @default(now())
  completedAt           DateTime?
  updatedAt             DateTime              @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([anchorTransactionId])
  @@map("fiat_withdrawal")
}
