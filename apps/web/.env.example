# ===== NextAuth =====
NEXTAUTH_URL=http://localhost:3000
# Gere com: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=REPLACE_ME_RANDOM_BASE64

# ===== Aegis API =====
AEGIS_API_URL=http://localhost:4000
# Auth do dashboard é por SESSÃO DO USUÁRIO: o NextAuth recebe um session token
# da API no login e o dashboard o reencaminha server-side (lido do JWT httpOnly,
# nunca chega ao browser). Não precisa mais de AEGIS_API_KEY de agente — rotação
# de key de agente não exige mais redeploy.
