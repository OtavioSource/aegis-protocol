# ===== NextAuth =====
NEXTAUTH_URL=http://localhost:3000
# Gere com: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=REPLACE_ME_RANDOM_BASE64

# ===== Aegis API =====
AEGIS_API_URL=http://localhost:4000
# Chave cr_ de um Agent (exibida pelo `pnpm --filter @aegis/api db:seed`).
# Usada server-side pelo dashboard — nunca chega ao browser.
AEGIS_API_KEY=cr_REPLACE_ME
