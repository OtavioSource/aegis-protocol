# Aegis API key (formato cr_...). Pegue rodando `pnpm --filter @aegis/api db:seed`
AEGIS_API_KEY=cr_REPLACE_ME

# URL base da Aegis API. Default localhost se omitido.
AEGIS_API_URL=http://localhost:4000

# Vendor cadastrado com wallet sponsored ACTIVE (obtido via POST /v1/vendors)
VENDOR_ID=replace_with_vendor_uuid
