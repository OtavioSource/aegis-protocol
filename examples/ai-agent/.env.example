# Aegis Protocol AI Agent Demo
# Copy this file to .env and fill in the values

# Anthropic API key — get at https://console.anthropic.com
# Leave empty to use --mock mode (no API key needed)
ANTHROPIC_API_KEY=sk-ant-...

# From `pnpm --filter api db:seed` output
DEMO_API_KEY=cr_...
DEMO_AGENT_ID=...

# Aegis Protocol API URL
API_URL=http://localhost:3001

# Dashboard URL (shown in approval prompts)
DASHBOARD_URL=http://localhost:3000
